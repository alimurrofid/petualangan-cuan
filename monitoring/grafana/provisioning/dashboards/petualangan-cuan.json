{
  "title": "Petualangan Cuan Logs",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Backend Log Volume per Minute",
      "datasource": "Loki",
      "targets": [{"expr": "sum(rate({container=\"petualangan_cuan_backend\"}[1m])) by (container)"}],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "LLM Server Log Volume per Minute",
      "datasource": "Loki",
      "targets": [{"expr": "sum(rate({container=\"petualangan_cuan_llm\"}[1m])) by (container)"}],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "Whisper Server Log Volume per Minute",
      "datasource": "Loki",
      "targets": [{"expr": "sum(rate({container=\"petualangan_cuan_whisper\"}[1m])) by (container)"}],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "Database Log Volume per Minute",
      "datasource": "Loki",
      "targets": [{"expr": "sum(rate({container=\"petualangan_cuan_db\"}[1m])) by (container)"}],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "WA Gateway Log Volume per Minute",
      "datasource": "Loki",
      "targets": [{"expr": "sum(rate({container=\"petualangan_cuan_wa_gateway\"}[1m])) by (container)"}],
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "fixed", "fixedColor": "green"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "logs",
      "title": "WA Gateway Logs (Live)",
      "datasource": "Loki",
      "targets": [{"expr": "{container=\"petualangan_cuan_wa_gateway\"}"}],
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "type": "timeseries",
      "title": "Uptime Kuma Log Volume per Minute",
      "datasource": "Loki",
      "targets": [{"expr": "sum(rate({container=\"petualangan_cuan_uptime\"}[1m])) by (container)"}],
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeseries",
      "title": "Monitoring Infra Log Volume (Grafana, Loki, Promtail)",
      "datasource": "Loki",
      "targets": [
        {"expr": "sum(rate({container=\"petualangan_cuan_grafana\"}[1m])) by (container)"},
        {"expr": "sum(rate({container=\"petualangan_cuan_loki\"}[1m])) by (container)"},
        {"expr": "sum(rate({container=\"petualangan_cuan_promtail\"}[1m])) by (container)"}
      ],
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10},
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    }
  ]
}