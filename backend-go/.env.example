# Server Configuration
PORT=8080

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=petualangan_cuan
DB_PORT=5432

# Security & Authentication (JWT)
JWT_SECRET=SECRET_KEY_CUAN
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=72h

# Google OAuth 2.0 Configuration
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Frontend Integration (CORS)
FRONTEND_URL=http://localhost:5173

# Whisper Services (Local Transcription)
LOCAL_WHISPER_URL=http://whisper-server:8000

# AI Provider Configuration
# Pilih provider: "local" (default) atau "external"
AI_PROVIDER=local

# Local LLM (digunakan saat AI_PROVIDER=local)
LOCAL_LLM_URL=http://llm-server:8080

# External AI API (digunakan saat AI_PROVIDER=external)
# Contoh: OpenRouter, OpenAI, Groq, dsb.
EXTERNAL_AI_URL=https://openrouter.ai/api/v1/chat/completions
EXTERNAL_AI_API_KEY=your_external_api_key_here
EXTERNAL_AI_MODEL=google/gemini-2.0-flash-001